# Copy to `.env` for local dev. On Vercel: Project → Settings → Environment Variables
# (same names). Redeploy after adding or changing values — Vite bakes these in at build time.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
